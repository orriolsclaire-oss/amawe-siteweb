// Témoignages — portfolio asymétrique en grille 6 colonnes
// Paula 1ère, Danièle dernière (bas droite). 4 rangées asymétriques sm/lg avec stacks pour combler.
// span: "sm" = 2/6 cols, "lg" = 4/6 cols
// type "stack" = colonne d'éléments empilés (textes + screenshots mélangés) pour matcher la hauteur de la colonne sm voisine
const temoignages = [
  // Row 1 — Paula (sm) | Hélène (lg, longue citation)
  // Paula : alignée en bas (mt-auto) avec 5 étoiles dans le vide au-dessus
  { type: "text", citation: "Un stage hors du commun duquel je sors régénérée, remplie d'énergie et d'amour. Juste un grand merci.", auteur: "Paula", contexte: "", span: "sm", stars: true, align: "end" },
  { type: "text", citation: "Un stage qui a lancé le début de changements d'ampleur. Dès le début, il a été marqué par ce déclic : « je m'autorise à » partir en stage, m'occuper de moi, plonger aussi dans l'inconnu. Je pensais que la Détox alimentaire serait prépondérante, le stage est allé au-delà de mes attentes. Vous nous avez conçu un programme tellement complet et cohérent, respectueux de tous les participants. Le cadre proposé sécurisant et le groupe était sensas. Merci pour tout.", auteur: "Hélène", contexte: "", span: "lg" },
  // Row 2 — Stack [Carine + Séverine + Céline] (lg) | Joëlle (sm haute, crop top autorisé)
  {
    type: "stack",
    span: "lg",
    items: [
      { kind: "text", citation: "Plus d'une semaine après être rentrée, je reste sur ma première impression : c'était réellement le plus beau cadeau que je pouvais m'offrir. Je me sens respirer, mes épaules sont davantage ouvertes, je pose plus aisément des mots sur mes ressentis.", auteur: "Carine", contexte: "" },
      { kind: "screenshot", src: "/images/temoignage-severine.webp", alt: "Témoignage de Séverine après un stage Amawé — ateliers libérateurs, rencontres merveilleuses, début d'un nouveau chapitre" },
      { kind: "text", citation: "Merci encore pour ce stage qui m'a apporté une vision globale de ma santé. Je ne vous remercierai jamais assez pour tout ce que j'ai appris chez vous !", auteur: "Céline", contexte: "" },
    ],
  },
  { type: "screenshot", src: "/images/temoignage-joelle.webp", alt: "Témoignage de Joëlle après le stage Voyage au Cœur de Soi Amawé — partager, rire, pleurer, méditer, ressentir", span: "sm", crop: "top" },
  // Row 3 — Clélia (sm, plus petite car rangée raccourcie) | Stack [Lydia seule] (lg)
  { type: "screenshot", src: "/images/temoignage-clelia.webp", alt: "Témoignage de Clélia après une retraite Amawé — impression de rajeunir, silence révélateur, retour transformée et pleine d'énergie", span: "sm" },
  {
    type: "stack",
    span: "lg",
    items: [
      { kind: "text", citation: "Explorer, se recentrer, se laisser guider, se purifier… Le silence m'a permis d'aller chercher au plus profond mes émotions, mes besoins. Grâce à la force du groupe nous avons été portés et pu aller jusqu'au bout de cette belle aventure. Les séances de danse ont été intenses et libératrices. Les repas nous ont régalé les papilles et les yeux. Ces quelques jours de déconnexion avec le quotidien rempli de sur-stimulations m'aura permis de me recentrer sur les choses importantes et de me reconnecter avec la nature. Je repars de cette retraite avec une nouvelle énergie, l'esprit apaisé et le cœur rempli de joie. C'est un magnifique cadeau que je me suis offert. Merci Claire et merci au groupe.", auteur: "Lydia", contexte: "" },
    ],
  },
  // Row 4 — Solenn (sm, plus de place) | Stack [Nathalie + Laurence + Danièle] (lg) — Danièle = dernier visuel
  { type: "screenshot", src: "/images/temoignage-solenn.webp", alt: "Témoignage de Solenn après une retraite Amawé — silence, ancrage, danse, ressourcement", span: "sm" },
  {
    type: "stack",
    span: "lg",
    items: [
      { kind: "screenshot", src: "/images/temoignage-nathalie.webp", alt: "Témoignage de Nathalie après un stage Amawé — sortir de sa zone de confort, repas parfaits, vivre l'instant présent et écouter son corps en pleine conscience" },
      { kind: "screenshot", src: "/images/temoignage-laurence.webp", alt: "Témoignage de Laurence après la Retraite Danse & Silence Amawé — traverser le deuil dans la nature, douceur, bienveillance, sentiment de plénitude et déposer sa peine" },
      { kind: "screenshot", src: "/images/temoignage-daniele.webp", alt: "Témoignage de Danièle après un stage Amawé — la plus belle expérience, simplicité et amour inconditionnel envers la nature, reconnexion à la nature et au mouvement" },
    ],
  },
]

// Compte total des avis textes pour le JSON-LD (les screenshots ne sont pas des reviews structurées)
const reviewCount = temoignages.reduce((sum, t) => {
  if (t.type === "text") return sum + 1
  if (t.type === "stack") return sum + (t.items?.filter((it) => it.kind === "text").length ?? 0)
  return sum
}, 0)

// JSON-LD Review/AggregateRating schema pour SEO (rich snippets Google)
const reviewsSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Stages & Retraites Amawé",
  description: "Stages, retraites et immersions de santé holistique en pleine nature dirigés par Claire Orriols",
  provider: {
    "@type": "Person",
    name: "Claire Orriols",
    url: "https://amawe.com",
  },
  areaServed: { "@type": "Country", name: "France" },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5",
    reviewCount: String(reviewCount),
    bestRating: "5",
    worstRating: "5",
  },
  review: temoignages.flatMap((t) => {
    if (t.type === "text") {
      return [{
        "@type": "Review",
        author: { "@type": "Person", name: t.auteur },
        reviewBody: t.citation,
        reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
        ...(t.contexte ? { itemReviewed: { "@type": "Service", name: t.contexte } } : {}),
      }]
    }
    if (t.type === "stack") {
      return (t.items ?? [])
        .filter((it) => it.kind === "text")
        .map((it) => ({
          "@type": "Review",
          author: { "@type": "Person", name: it.auteur },
          reviewBody: it.citation,
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          ...(it.contexte ? { itemReviewed: { "@type": "Service", name: it.contexte } } : {}),
        }))
    }
    return []
  }),
}
