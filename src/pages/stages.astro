    <!-- HISTORIQUE -->
    <section class="bg-[var(--color-warm)] py-16 md:py-20">
      <div class="mx-auto max-w-5xl px-6">
        <div class="max-w-3xl">
          <p class="section-label mb-3 text-[var(--color-sage-dark)]">DEPUIS 2022</p>
          <h2 class="text-3xl md:text-4xl">L'historique des stages Amawé</h2>
          <div class="divider mt-5" style="background-color: var(--color-sage-dark);"></div>
        </div>

        {/* Timeline serpentin — hauteurs variables par rangée selon nombre d'events */}
        {(() => {
          const numRows = historique.length
          // Hauteur de chaque rangée (= espacement vers la rangée suivante) selon le nombre d'events
          const rowHeights = historique.map((a, i) => {
            let h = a.evenements.length >= 3 ? 180 : 155
            if (i === 0) h += 30  // petit espace sous la première rangée pour aérer la card
            return h
          })
          // Calcul des Y de chaque ligne
          const lineYs: number[] = []
          let cumY = 30
          for (let i = 0; i < numRows; i++) {
            lineYs.push(cumY)
            if (i < numRows - 1) cumY += rowHeights[i]
          }
          const totalH = lineYs[lineYs.length - 1] + 130
          const lineLeft = 150
          const lineRight = 880
          let pathD = `M ${lineLeft} ${lineYs[0]} L ${lineRight} ${lineYs[0]}`
          for (let i = 1; i < numRows; i++) {
            const yPrev = lineYs[i - 1]
            const y = lineYs[i]
            const gap = y - yPrev
            const curveOffset = (gap / 2) * 0.8  // arrondi entre-deux
            if (i % 2 === 1) {
              const cx = Math.min(lineRight + curveOffset, 998)
              pathD += ` C ${cx} ${yPrev}, ${cx} ${y}, ${lineRight} ${y} L ${lineLeft} ${y}`
            } else {
              const cx = Math.max(lineLeft - curveOffset, 2)
              pathD += ` C ${cx} ${yPrev}, ${cx} ${y}, ${lineLeft} ${y} L ${lineRight} ${y}`
            }
          }
          return (
            <div class="relative mt-10 hidden md:block" style={`height: ${totalH}px;`}>
              <svg
                class="absolute inset-0 h-full w-full"
                viewBox={`0 0 1000 ${totalH}`}
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <path d={pathD} stroke="var(--color-accent)" stroke-width="2" fill="none" stroke-opacity="0.7" />
                {/* Segment au-dessus de Summer Camp (1er event de 2026, futur) : on efface puis on trace en pointillés */}
                <path d={`M ${lineLeft} ${lineYs[0]} L 380 ${lineYs[0]}`} stroke="var(--color-warm)" stroke-width="3" fill="none" />
                <path d={`M ${lineLeft} ${lineYs[0]} L 380 ${lineYs[0]}`} stroke="var(--color-accent)" stroke-width="2" stroke-dasharray="5 5" fill="none" stroke-opacity="0.7" />
              </svg>
              {/* Cercle plein marquant la fin de la ligne (= début chronologique, 2022) */}
              {(() => {
                const lastIdx = numRows - 1
                const endXPct = lastIdx % 2 === 0 ? "88%" : "13%"
                const endY = lineYs[lastIdx]
                return (
                  <span
                    class="absolute h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--color-accent)]"
                    style={`top: ${endY}px; left: ${endXPct};`}
                    aria-hidden="true"
                  ></span>
                )
              })()}
              {historique.map((annee, i) => {
                const y = lineYs[i]
                return (
                  <div>
                    <p
                      class="absolute font-['Josefin_Sans',sans-serif] text-3xl font-light leading-none text-[var(--color-accent-dark)]"
                      style={`top: ${y + 22}px; left: 0; width: 100px;`}
                    >
                      {annee.annee}
                    </p>
                    <div
                      class="absolute flex flex-wrap items-start gap-5"
                      style={`top: ${y + 22}px; left: 15%; right: 13%;`}
                    >
                      {annee.evenements.map((ev) => {
                        const Tag = ev.href ? "a" : "div"
                        const linkProps = ev.href ? { href: ev.href } : {}
                        return (
                          <Tag
                            class={`relative min-w-[210px] flex-1 ${ev.isFuture ? "rounded-xl bg-[var(--color-accent-light)]/40 px-3 py-2" : ""} ${ev.href ? "block transition-shadow hover:shadow-md" : ""}`}
                            {...linkProps}
                          >
                            <span
                              class="absolute h-3 w-3 -translate-x-1/2 rounded-full border-2 border-[var(--color-accent)] bg-[var(--color-warm)]"
                              style="top: -28px; left: 50%;"
                              aria-hidden="true"
                            ></span>
                            {ev.isFuture && (
                              <p class="mb-1 text-[10px] font-semibold uppercase tracking-[0.15em] text-[var(--color-accent-dark)]">À venir</p>
                            )}
                            <p class="font-['Josefin_Sans',sans-serif] text-xl text-[var(--color-primary)] leading-tight">{ev.nom}</p>
                            <p class="mt-0.5 text-xs uppercase tracking-[0.1em] text-[var(--color-text-light)]">{ev.date} · {ev.lieu}</p>
                            <p class="mt-1 text-base leading-snug text-[var(--color-text-medium)]">{ev.thematique}</p>
                          </Tag>
                        )
                      })}
                    </div>
                  </div>
                )
              })}
            </div>
          )
        })()}

        {/* Mobile fallback — stack vertical simple */}
        <div class="mt-10 space-y-6 md:hidden">
          {historique.map((annee) => (
            <div>
              <p class="font-['Josefin_Sans',sans-serif] text-lg font-light leading-none text-[var(--color-accent-dark)]">{annee.annee}</p>
              <div class="mt-3 space-y-3">
                {annee.evenements.map((ev) => {
                  const Tag = ev.href ? "a" : "div"
                  const linkProps = ev.href ? { href: ev.href } : {}
                  return (
                    <Tag
                      class={`${ev.isFuture ? "rounded-xl bg-[var(--color-accent-light)]/40 px-3 py-2" : "border-l-2 pl-3"} ${ev.href ? "block" : ""}`}
                      style={ev.isFuture ? "" : "border-color: var(--color-accent);"}
                      {...linkProps}
                    >
                      {ev.isFuture && (
                        <p class="mb-1 text-[10px] font-semibold uppercase tracking-[0.15em] text-[var(--color-accent-dark)]">À venir</p>
                      )}
                      <p class="font-['Josefin_Sans',sans-serif] text-base text-[var(--color-primary)]">{ev.nom}</p>
                      <p class="text-[10px] uppercase tracking-[0.1em] text-[var(--color-text-light)]">{ev.date} · {ev.lieu}</p>
                      <p class="mt-0.5 text-sm leading-snug text-[var(--color-text-medium)]">{ev.thematique}</p>
                    </Tag>
                  )
                })}
              </div>
            </div>
          ))}
        </div>

        <p class="mx-auto mt-10 max-w-3xl text-center font-['Josefin_Sans',sans-serif] text-lg font-medium italic text-[var(--color-accent-dark)] md:text-xl">
          4 ans et plus d'une centaine de personnes accompagnées en présentiel.
        </p>
      </div>
    </section>

