          <span class="absolute left-0 top-0 h-8 w-[2px] bg-[var(--color-accent)]" aria-hidden="true"></span>
          <span class="absolute left-0 top-0 h-[2px] w-8 bg-[var(--color-accent)]" aria-hidden="true"></span>
          <span class="absolute right-0 bottom-0 h-8 w-[2px] bg-[var(--color-accent)]" aria-hidden="true"></span>
          <span class="absolute right-0 bottom-0 h-[2px] w-8 bg-[var(--color-accent)]" aria-hidden="true"></span>
