            { src: "/images/stage-tarte-fraises-crue-saine.webp", alt: "Tarte aux fraises crue, cuisine vivante pendant un stage Amawé" },
            { src: "/images/stage-salle-pratique-tapis-aveyron.webp", alt: "Salle de pratique du stage Amawé avec tapis colorés et baies vitrées sur la nature" },
            { src: "/images/stage-feu-camp-cercle-soir.webp", alt: "Cercle autour du feu de camp un soir de stage Amawé" },
