          ]
          return photos.concat(photos.map(p => ({ ...p, alt: "" }))).map((img, i) => (
            <img
              src={img.src}
              alt={img.alt}
              aria-hidden={i >= photos.length ? "true" : undefined}
              loading="lazy"
              class="h-56 md:h-64 w-auto flex-shrink-0 rounded-xl object-cover"
            />
          ))
        })()}
        </div>
      </div>
      <script is:inline>
        (() => {
          const SPEED = 60 // pixels per second
          const sections = document.querySelectorAll('[aria-label="Aperçu des stages passés"]')
          sections.forEach((section) => {
            const track = section.querySelector('.marquee-track')
            const prev = section.querySelector('[data-marquee-prev]')
            const next = section.querySelector('[data-marquee-next]')
            if (!track || !prev || !next) return
            const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
            let pos = 0
            let isPaused = reduced
            let lastTime = performance.now()
            let resumeTimer
            let halfWidth = 0
            const updateHalfWidth = () => { halfWidth = track.scrollWidth / 2 }
            updateHalfWidth()
            window.addEventListener('resize', updateHalfWidth)
            track.querySelectorAll('img').forEach((img) => {
              if (img.complete) return
              img.addEventListener('load', updateHalfWidth, { once: true })
              img.addEventListener('error', updateHalfWidth, { once: true })
            })
            // Recompute periodically over first 5 seconds while images stream in
            let recomputes = 0
            const recomputeTimer = setInterval(() => {
              updateHalfWidth()
              if (++recomputes > 25) clearInterval(recomputeTimer)
            }, 200)
            const setTransform = () => {
              let displayPos = pos
              if (halfWidth > 0) {
                displayPos = pos % halfWidth
                if (displayPos > 0) displayPos -= halfWidth
              }
              track.style.transform = `translate3d(${Math.round(displayPos)}px, 0, 0)`
            }
            const tick = (now) => {
              const dt = (now - lastTime) / 1000
              lastTime = now
              if (!isPaused) {
                pos -= SPEED * dt
                setTransform()
              }
              requestAnimationFrame(tick)
            }
            requestAnimationFrame((t) => { lastTime = t; tick(t) })
            const scheduleResume = () => {
              clearTimeout(resumeTimer)
              resumeTimer = setTimeout(() => { isPaused = false }, 2000)
            }
            const nudge = (delta) => {
              isPaused = true
              const start = pos
              const target = pos + delta
              const duration = 400
              const startTime = performance.now()
              const easeOut = (t) => 1 - Math.pow(1 - t, 3)
              const step = (now) => {
                const t = Math.min(1, (now - startTime) / duration)
                pos = start + (target - start) * easeOut(t)
                setTransform()
                if (t < 1) requestAnimationFrame(step)
                else scheduleResume()
              }
              requestAnimationFrame(step)
            }
            prev.addEventListener('click', () => nudge(400))
            next.addEventListener('click', () => nudge(-400))
            section.addEventListener('mouseenter', () => { isPaused = true; clearTimeout(resumeTimer) })
            section.addEventListener('mouseleave', () => { clearTimeout(resumeTimer); isPaused = false })
          })
        })()
      </script>
    </section>

    <!-- L'ESPRIT D'UN STAGE -->
    <section class="bg-[var(--color-warm)] py-8 md:py-10">
