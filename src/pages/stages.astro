      >
        <span aria-hidden="true">›</span>
      </button>
      <div class="marquee-wrapper">
        <div class="marquee-track gap-4">
        {(() => {
          const photos = [
            { src: "/images/groupe-ei-2.webp", alt: "Groupe Énergie Illimitée au coucher de soleil sur la plage" },
            { src: "/images/stage-cuisine-mezze-vivante.webp", alt: "Plateau de mezze et dips colorés en cuisine vivante, stage Amawé" },
            { src: "/images/stage-grand-groupe-aveyron-celebration.webp", alt: "Grand groupe en célébration devant la maison de l'écolieu Amawé en Sud Aveyron" },
            { src: "/images/stage-claire-transmission-flipchart.webp", alt: "Claire Orriols transmettant la naturopathie au flipchart pendant un stage Amawé" },
            { src: "/images/stage-mouvement-naturel-foret.webp", alt: "Pratique de mouvement naturel en forêt pendant un stage Amawé" },
            { src: "/images/stage-pratique-duo-salle-voutee-pierre.webp", alt: "Pratique en duo dans la grande salle voûtée en pierre, stage Amawé" },
            { src: "/images/stage-energy-balls-cuisine-saine.webp", alt: "Energy balls maison préparées en atelier cuisine saine pendant un stage Amawé" },
            { src: "/images/stage-baignade-riviere-aveyron-ete.webp", alt: "Baignade collective en rivière lors d'un stage Amawé en été" },
            { src: "/images/stage-cake-fleurs-comestibles.webp", alt: "Cake aux fleurs comestibles, cuisine d'un stage Amawé" },
            { src: "/images/stage-mouvement-libre-celebration-groupe.webp", alt: "Mouvement libre en groupe, célébration pendant un stage Amawé" },
            { src: "/images/stage-soupe-verte-salade-detox.webp", alt: "Soupe verte et salade détox, repas d'un stage Amawé" },
            { src: "/images/stage-passerelle-coucher-soleil-aveyron.webp", alt: "Groupe contemplant un coucher de soleil sur une passerelle, stage Amawé" },
            { src: "/images/stage-claire-cuisine-cake-fraises.webp", alt: "Claire Orriols préparant un cake aux fraises en atelier cuisine vivante" },
            { src: "/images/stage-bain-froid-riviere-aveyron.webp", alt: "Bain glacé en rivière pendant un stage Amawé en hiver" },
            { src: "/images/stage-baignade-groupe-couchant-aveyron.webp", alt: "Groupe en maillot de bain au bord de la rivière au coucher du soleil, stage Amawé" },
            { src: "/images/stage-yoga-pieds-tapis-pratique.webp", alt: "Pratique de yoga pieds nus sur tapis lors d'un stage Amawé" },
            { src: "/images/stage-marche-prairie-ciel-bleu.webp", alt: "Marche en groupe dans la prairie sous un ciel bleu, stage Amawé" },
            { src: "/images/stage-arche-pierre-aveyron-groupe.webp", alt: "Groupe sous l'arche de pierre, stage Amawé en Sud Aveyron" },
            { src: "/images/stage-ecriture-cercle-salle-aveyron.webp", alt: "Atelier d'écriture en cercle dans la salle de pratique de l'écolieu" },
