                            &laquo;&nbsp;{it.citation}&nbsp;&raquo;
                          </blockquote>
                          <figcaption class="mt-3 border-t border-[var(--color-border)] pt-2">
                            <p class="font-['Josefin_Sans',sans-serif] text-sm leading-tight text-[var(--color-primary)]">{it.auteur}</p>
