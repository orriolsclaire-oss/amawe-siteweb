---
import Layout from "~/layouts/Layout.astro"
import Header from "~/components/Header.astro"
import Footer from "~/components/Footer.astro"
import SubscribeForm from "~/components/SubscribeForm.astro"

const pageTitle = "Ressources gratuites — Amawé | Audit santé, newsletter, fiches"
const pageDescription =
  "Toutes les ressources gratuites Amawé pour reprendre le pouvoir sur ta santé globale : audit Roue Amawé, SuperLetter hebdomadaire, fiches mémo et dossiers santé."

// Ressources actuelles + à venir
const ressourcesActuelles = [
  {
    label: "PDF · 10 PAGES · 10 MIN",
    titre: "L'audit Roue de la Santé Amawé",
    sous: "Auto-évalue tes 16 fondamentaux et influenceurs de ta vitalité",
    description:
      "Je te guide avec un PDF pour auto-évaluer ton niveau de santé sur les 16 domaines, identifier tes forces et tes zones de travail, et savoir par quel domaine commencer en priorité. Envoyé par email.",
    cta: "Recevoir l'audit",
    href: "/audit-roue-sante/",
    statut: "disponible",
    image: "/images/audit-roue-sante-mockup.webp",
    imageAlt: "Audit Roue Amawé — PDF mockup des 16 fondamentaux de vitalité",
    fit: "contain",
  },
  {
    label: "NEWSLETTER · HEBDO",
    titre: "La SuperLetter",
    sous: "1 sujet de santé globale approfondi par semaine",
    description:
      "Chaque semaine, reçois des conseils en nutrition, mouvement, gestion du stress, bien-être et santé holistique (detox, sommeil, respiration, système nerveux, rythmes, émotions, mindset…). Rejoins près de 20 000 abonnés.",
    cta: "Recevoir la SuperLetter",
    href: "#newsletter",
    statut: "disponible",
    image: null,
    imageAlt: "",
  },
  {
    label: "PDF + VIDÉOS · BIENTÔT",
    titre: "Snacks de mouvement",
    sous: "Bouger en quelques minutes, plusieurs fois par jour",
    description:
      "Des micro-pratiques de mouvement à intégrer dans ta journée, sans tapis, sans tenue, sans excuse. À grignoter quand tu veux.",
    cta: "Bientôt disponible",
    href: "#newsletter",
    statut: "à venir",
    image: "/images/snacks-mouvement.webp",
    imageAlt: "Claire Orriols en MovNat — mouvement naturel en pleine nature, pratique au quotidien",
  },
]

const ressourcesAVenir = [
  {
    titre: "PDF · Snacks de mouvement",
    description:
      "Des micro-pratiques de mouvement à intégrer dans ta journée, sans tapis, sans tenue, sans excuse. À grignoter quand tu veux.",
  },
  {
    titre: "À venir",
    description: "Programmation en cours.",
  },
  {
    titre: "À venir",
    description: "Programmation en cours.",
  },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <main class="pt-20">
    <!-- Hero -->
    <section class="bg-[var(--color-surface)] py-12 md:py-16">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <p class="section-label mb-3 text-[var(--color-sage-dark)]">RESSOURCES GRATUITES</p>
        <h1 class="!text-3xl md:!text-5xl">
          Entre dans l'écosystème Amawé,
          <span class="block italic text-[var(--color-accent-dark)]">à ton rythme.</span>
        </h1>
        <div class="divider mx-auto mt-5" style="background-color: var(--color-sage-dark);"></div>
        <p class="mt-6 text-base leading-relaxed text-[var(--color-text-medium)] md:text-lg">
          Tout ce qu'on partage gratuitement chez Amawé : un audit pour faire le point,
          une newsletter hebdomadaire pour creuser un sujet par semaine, et bientôt
          d'autres ressources pour aller plus loin.
        </p>
      </div>
    </section>


    <!-- Ressources disponibles -->
    <section class="bg-[var(--color-warm)] pt-14 pb-20 md:pt-20 md:pb-28">
      <div class="mx-auto max-w-5xl px-6">
        <div class="max-w-3xl">
          <p class="section-label mb-4">DISPONIBLES MAINTENANT</p>
          <h2 class="text-3xl md:text-4xl">Pour démarrer</h2>
          <div class="divider mt-6" style="background-color: var(--color-sage-dark);"></div>
        </div>

        <div class="mt-10 space-y-4 sm:space-y-5">
          {ressourcesActuelles.map((r) => {
            const isComingSoon = r.statut === "à venir"
            const Tag = isComingSoon ? "div" : "a"
            const linkProps = isComingSoon ? {} : { href: r.href }
            return (
            <Tag
              {...linkProps}
              class:list={[
                "group flex flex-col gap-4 rounded-2xl bg-[var(--color-surface)] p-4 shadow-sm sm:flex-row sm:gap-5 sm:p-5",
                isComingSoon ? "cursor-default opacity-80" : "transition-shadow hover:shadow-md",
              ]}
            >
              <div class="flex-shrink-0 sm:w-36 md:w-44">
                {r.image && (
                  <img
                    src={r.image}
                    alt={r.imageAlt}
                    width="600"
                    height="600"
                    loading="lazy"
                    class:list={[
                      "aspect-square w-full rounded-xl",
                      r.fit === "contain" ? "object-contain bg-[var(--color-warm)] p-1" : "object-cover",
                    ]}
                  />
                )}
                {!r.image && (
                  <div class="relative aspect-square w-full rounded-xl bg-[var(--color-sage-dark)] flex items-center justify-center px-4">
                    <svg
                      aria-hidden="true"
                      width="48"
                      height="44"
                      viewBox="0 0 44 40"
                      fill="none"
                      stroke="var(--color-surface)"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="absolute left-3 top-3 -rotate-12"
                    >
                      <rect x="3" y="12" width="28" height="20" rx="2" />
                      <path d="M3 14 L17 25 L31 14" />
                      <path d="M34 4 C40 5 41 12 38 16 C34 16 31 13 31 9 C31 6 32 5 34 4 Z" stroke-width="1.4" fill="var(--color-surface)" fill-opacity="0.2" />
                      <line x1="34" y1="6" x2="37" y2="13" stroke-width="1" />
                    </svg>
                    <p class="font-['Josefin_Sans',sans-serif] text-2xl text-[var(--color-surface)] text-center leading-tight sm:text-3xl">
                      La<br/>SuperLetter
                    </p>
                  </div>
                )}
              </div>
              <div class="flex flex-1 flex-col">
                <p class="section-label text-[var(--color-accent)]">{r.label}</p>
                <p class="mt-1.5 font-['Josefin_Sans',sans-serif] text-xl leading-tight text-[var(--color-primary)] md:text-2xl">{r.titre}</p>
                <p class="mt-1 text-xs italic text-[var(--color-text-light)] sm:text-sm">{r.sous}</p>
                <p class="mt-2 flex-1 text-base leading-relaxed text-[var(--color-text-medium)]">{r.description}</p>
                <span class="mt-3 inline-flex items-start gap-3 text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-accent)]">
                  <span class="mt-[5px] block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]" aria-hidden="true"></span>
                  <span class="relative pb-1">
                    <span>{r.cta}</span>
                    <span class="absolute bottom-0 left-0 h-px w-0 bg-[var(--color-accent)] transition-all duration-500 group-hover:w-full" aria-hidden="true"></span>
                  </span>
                </span>
              </div>
            </Tag>
            )
          })}
        </div>

        <!-- Rejoindre la communauté -->
        <div class="mt-16 text-center sm:mt-20">
          <p class="section-label mb-5 text-[var(--color-sage-dark)]">REJOINDRE LA COMMUNAUTÉ</p>
          <div class="flex items-center justify-center gap-6">
            <a
              href="https://instagram.com/amawefrance"
              target="_blank"
              rel="noopener"
              aria-label="Suivre Amawé sur Instagram"
              class="text-[var(--color-text-medium)] transition-colors hover:text-[var(--color-accent-dark)]"
            >
              <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a
              href="https://www.facebook.com/amawefrance"
              target="_blank"
              rel="noopener"
              aria-label="Suivre Amawé sur Facebook"
              class="text-[var(--color-text-medium)] transition-colors hover:text-[var(--color-accent-dark)]"
            >
              <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
          <p class="mt-3 text-sm text-[var(--color-text-light)]">
            <a href="https://instagram.com/amawefrance" target="_blank" rel="noopener" class="hover:text-[var(--color-accent-dark)] transition-colors">@amawefrance</a> · personnel : <a href="https://instagram.com/claireorriols" target="_blank" rel="noopener" class="hover:text-[var(--color-accent-dark)] transition-colors">@claireorriols</a>
          </p>
        </div>
      </div>
    </section>
    <!-- Newsletter signup -->
    <section id="newsletter" class="bg-[var(--color-accent-dark)] py-12 md:py-16">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <svg
          aria-hidden="true"
          width="44"
          height="40"
          viewBox="0 0 44 40"
          fill="none"
          stroke="var(--color-surface)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mx-auto mb-3"
        >
          <rect x="3" y="12" width="28" height="20" rx="2" />
          <path d="M3 14 L17 25 L31 14" />
          <path d="M34 4 C40 5 41 12 38 16 C34 16 31 13 31 9 C31 6 32 5 34 4 Z" stroke-width="1.4" fill="var(--color-surface)" fill-opacity="0.2" />
          <line x1="34" y1="6" x2="37" y2="13" stroke-width="1" />
        </svg>
        <p class="section-label mb-3" style="color: var(--color-surface);">LA SUPERLETTER</p>
        <h2 class="text-3xl text-[var(--color-surface)] md:text-4xl" style="color: var(--color-surface);">
          1 newsletter par semaine.<br />
          1 sujet. Des pratiques concrètes.
        </h2>
        <div class="divider mx-auto mt-5" style="background-color: var(--color-surface);"></div>

        <p class="mt-6 text-[var(--color-surface)]/80">
          Chaque semaine, reçois des conseils en nutrition, mouvement, gestion du stress, bien-être et santé holistique (detox, sommeil, respiration, système nerveux, rythmes, émotions, mindset…). Rejoins près de 20 000 abonnés.
        </p>

        <SubscribeForm
          intent="newsletter"
          theme="dark"
          cta="Rejoindre"
          extraFields={["name"]}
          nameLabel="Prénom"
          namePlaceholder="Ton prénom"
          emailLabel="Email"
          emailPlaceholder="Ton adresse email"
          buttonClass="btn-accent whitespace-nowrap leading-tight w-full !bg-[var(--color-sage-dark)] !border-[var(--color-sage-dark)] hover:!bg-[var(--color-warm)] hover:!text-[var(--color-primary)] hover:!border-[var(--color-warm)]"
          class="mt-6 max-w-md md:max-w-none"
        />
      </div>
    </section>
  </main>
  <Footer />
</Layout>
