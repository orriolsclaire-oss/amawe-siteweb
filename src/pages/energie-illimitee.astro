---
import Layout from "~/layouts/Layout.astro"
import Header from "~/components/Header.astro"
import Footer from "~/components/Footer.astro"
import TestimonialCard from "~/components/TestimonialCard.astro"
import { getLangFromUrl, useTranslations } from "~/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const formUrl = "https://forms.gle/V8KsRaoJNLQnAi6c8"
const waitlistUrl = "https://forms.gle/tkNQmmHcy4XdVW6n7"
const calendarUrl = "https://calendar.app.google/FHzZyGNn5zqd1ZJq9"
const videoUrl = "https://www.youtube.com/embed/8rZzKqrOTsQ"

const resultBlocks = [
  {
    title: t("ei.results.body.title"),
    icon: "🌿",
    items: [t("ei.results.body.1"), t("ei.results.body.2"), t("ei.results.body.3")],
  },
  {
    title: t("ei.results.mind.title"),
    icon: "🧠",
    items: [t("ei.results.mind.1"), t("ei.results.mind.2"), t("ei.results.mind.3")],
  },
  {
    title: t("ei.results.emotions.title"),
    icon: "💛",
    items: [t("ei.results.emotions.1"), t("ei.results.emotions.2"), t("ei.results.emotions.3")],
  },
  {
    title: t("ei.results.life.title"),
    icon: "🚀",
    items: [t("ei.results.life.1"), t("ei.results.life.2"), t("ei.results.life.3")],
  },
]

const pillars = [
  {
    title: t("ei.pillar.1.title"),
    text: t("ei.pillar.1.text"),
    benefits: [t("ei.pillar.1.benefit.1"), t("ei.pillar.1.benefit.2"), t("ei.pillar.1.benefit.3")],
    num: "01",
    icon: "🌿",
  },
  {
    title: t("ei.pillar.2.title"),
    text: t("ei.pillar.2.text"),
    benefits: [t("ei.pillar.2.benefit.1"), t("ei.pillar.2.benefit.2"), t("ei.pillar.2.benefit.3")],
    num: "02",
    icon: "🤸",
  },
  {
    title: t("ei.pillar.3.title"),
    text: t("ei.pillar.3.text"),
    benefits: [t("ei.pillar.3.benefit.1"), t("ei.pillar.3.benefit.2"), t("ei.pillar.3.benefit.3")],
    num: "03",
    icon: "🧠",
  },
  {
    title: t("ei.pillar.4.title"),
    text: t("ei.pillar.4.text"),
    benefits: [t("ei.pillar.4.benefit.1"), t("ei.pillar.4.benefit.2"), t("ei.pillar.4.benefit.3")],
    num: "04",
    icon: "🎯",
  },
]

const bonuses = [
  { text: t("ei.bonus.1"), badge: "Offert" },
  { text: t("ei.bonus.4"), badge: "Offert" },
  { text: t("ei.bonus.5"), badge: "Offert" },
  { text: t("ei.bonus.6"), badge: "VIP" },
]

const faqs = [
  { q: t("ei.faq.1.q"), a: t("ei.faq.1.a") },
  { q: t("ei.faq.6.q"), a: t("ei.faq.6.a") },
  { q: t("ei.faq.3.q"), a: t("ei.faq.3.a") },
  { q: t("ei.faq.2.q"), a: t("ei.faq.2.a") },
  { q: t("ei.faq.4.q"), a: t("ei.faq.4.a") },
  { q: t("ei.faq.5.q"), a: t("ei.faq.5.a") },
]
---

<Layout
  title={`${t("ei.title")} — Amawe`}
  description={t("ei.hero.subtitle")}
>
  <Header />
  <main class="pt-20">

    <!-- ============================================
         1. HERO — 2 colonnes : texte + photo Claire
         ============================================ -->
    <section class="relative min-h-[85vh] flex items-center overflow-hidden" style="background: linear-gradient(135deg, #CE766A 0%, #8B5A7A 50%, #1A1A1A 100%);">
      <div class="relative z-10 mx-auto max-w-7xl px-6 py-24 md:py-32">

        <!-- Titre chapeau -->
        <h1 class="text-center font-['Josefin_Sans',sans-serif] tracking-tight uppercase text-6xl text-[var(--color-surface)] md:text-8xl lg:text-9xl leading-[0.9] drop-shadow-[0_4px_24px_rgba(0,0,0,0.25)]" style="font-weight: 250;">{t("ei.title")}</h1>

        <div class="mt-12 grid items-start gap-8 md:mt-16 md:grid-cols-2 md:gap-12 lg:gap-16">

        <!-- Colonne gauche : texte -->
        <div class="order-2 md:order-1">

          <!-- Texte descriptif -->
          <p class="max-w-xl text-lg font-semibold text-[var(--color-surface)] leading-relaxed md:text-xl">
            En 3 mois, tu :
          </p>
          <ul class="mt-3 max-w-xl space-y-2.5">
            <li class="flex items-start gap-3">
              <span class="mt-[0.65em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-warm-dark)]"></span>
              <span class="text-lg leading-relaxed text-[var(--color-surface)] md:text-xl"><strong class="font-semibold">restaures ta vitalité physique</strong></span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-[0.65em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-warm-dark)]"></span>
              <span class="text-lg leading-relaxed text-[var(--color-surface)] md:text-xl"><strong class="font-semibold">clarifies ton mental</strong></span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-[0.65em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-warm-dark)]"></span>
              <span class="text-lg leading-relaxed text-[var(--color-surface)] md:text-xl"><strong class="font-semibold">renforces ton équilibre émotionnel</strong></span>
            </li>
          </ul>
          <p class="mt-5 max-w-xl text-lg text-[var(--color-surface)]/80 leading-relaxed md:text-xl">
            Pour arrêter de t'épuiser, retrouver un élan solide, et mettre cette énergie au service de la vie que tu veux vraiment construire.
          </p>

          <!-- Punchline -->
          <div class="mt-8 border-l-4 border-[var(--color-accent)] pl-6">
            <p class="font-['Josefin_Sans',sans-serif] text-lg text-[var(--color-accent-light)] md:text-xl">
              {t("ei.hero.punchline")}
            </p>
          </div>

          <!-- CTA -->
          <div class="mt-10 flex flex-col items-center gap-3">
            <a href={waitlistUrl} target="_blank" rel="noopener noreferrer" class="btn-accent text-center leading-tight !bg-[var(--color-accent)] !border-[var(--color-accent)] hover:!bg-[var(--color-accent-light)] hover:!border-[var(--color-accent-light)] hover:!text-[var(--color-primary)]" set:html={lang === 'fr' ? 'Je candidate<br/>pour Énergie Illimitée' : t("ei.cta")}></a>
            <p class="text-sm text-center text-[var(--color-surface)]/50">{t("ei.cta.note")}</p>
          </div>

          <!-- Social Proof -->
          <div class="mt-10 flex flex-wrap items-center gap-6 border-t border-[var(--color-surface)]/10 pt-6 md:gap-8">
            <div>
              <p class="font-['Josefin_Sans',sans-serif] text-2xl text-[var(--color-accent-light)] md:text-3xl">9,5<span class="text-base text-[var(--color-accent-light)]/60 md:text-lg">/10</span></p>
              <p class="text-[10px] text-[var(--color-surface)]/50 uppercase tracking-wider">satisfaction participants</p>
            </div>
            <div class="h-6 w-px bg-[var(--color-surface)]/15 hidden sm:block"></div>
            <div>
              <p class="font-['Josefin_Sans',sans-serif] text-2xl text-[var(--color-accent-light)] md:text-3xl">3 mois</p>
              <p class="text-[10px] text-[var(--color-surface)]/50 uppercase tracking-wider">d'accompagnement</p>
            </div>
            <div class="h-6 w-px bg-[var(--color-surface)]/15 hidden sm:block"></div>
            <div>
              <p class="font-['Josefin_Sans',sans-serif] text-2xl text-[var(--color-accent-light)] md:text-3xl">2</p>
              <p class="text-[10px] text-[var(--color-surface)]/50 uppercase tracking-wider">immersions en presentiel</p>
            </div>
          </div>
        </div>

        <!-- Colonne droite : photo (vidéo à remettre plus tard) -->
        <div class="order-1 flex items-center md:order-2">
          <div class="relative w-full overflow-hidden rounded-lg shadow-2xl" style="aspect-ratio: 4/3;">
            <img
              src="/images/claire-ei-hero-coaching.webp"
              alt="Claire Orriols en animation — Programme Énergie Illimitée, transmission en présentiel"
              width="1600"
              height="1200"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="absolute inset-0 h-full w-full object-cover"
            />
          </div>
        </div>
        </div>
      </div>

      <!-- Ligne d'accent en bas du hero -->
      <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-accent)] via-[var(--color-accent)]/50 to-transparent"></div>
    </section>

    <!-- ============================================
         3. PROMESSE — Texte + photo portrait
         ============================================ -->
    <section class="py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <!-- Titre chapeau -->
        <p class="section-label mb-3 text-center text-[var(--color-accent)] tracking-[0.25em]">{lang === 'fr' ? "L'INTENTION" : 'THE INTENTION'}</p>
        <h2 class="text-center text-4xl md:text-5xl" set:html={t("ei.promise.title")}></h2>

        <div class="mt-14 grid items-center gap-12 md:mt-16 md:grid-cols-2 md:gap-20">
        <!-- Photo portrait (mobile : en premier) -->
        <div class="order-1 md:order-2">
          <img
            src="/images/claire-energie-illimitee.webp"
            alt="Claire Orriols — Programme Énergie Illimitée, accompagnement en santé holistique"
            width="683"
            height="1024"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="mx-auto aspect-[3/4] w-full max-w-md object-cover shadow-lg"
          />
        </div>
        <!-- Texte promesse -->
        <div class="order-2 md:order-1">
          <div class="divider"></div>
          <p class="mt-8 text-lg leading-relaxed text-[var(--color-text-medium)]">
            {t("ei.promise.intro")}
          </p>
          <p class="mt-6 text-xl font-semibold text-[var(--color-primary)]">Pendant 3 mois, tu es accompagné(e) pour :</p>
          <div class="mt-8 space-y-5">
            <div class="flex items-start gap-4 py-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--color-sage)] text-xs text-white">✓</span>
              <p class="text-[var(--color-text-medium)]"><strong class="font-semibold text-[var(--color-accent)]">Restaurer</strong> {t("ei.promise.1")}</p>
            </div>
            <div class="flex items-start gap-4 py-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--color-sage)] text-xs text-white">✓</span>
              <p class="text-[var(--color-text-medium)]"><strong class="font-semibold text-[var(--color-accent)]">Clarifier</strong> {t("ei.promise.2")}</p>
            </div>
            <div class="flex items-start gap-4 py-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--color-sage)] text-xs text-white">✓</span>
              <p class="text-[var(--color-text-medium)]"><strong class="font-semibold text-[var(--color-accent)]">Construire</strong> {t("ei.promise.3")}</p>
            </div>
          </div>
          <div class="mt-10 rounded-lg border border-[var(--color-border)] bg-[var(--color-warm)] p-6 sm:p-7">
            <p class="mb-4 text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-accent)]">{lang === 'fr' ? 'Ce que ça inclut' : 'What\'s included'}</p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="mt-[0.55em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                <span class="text-base text-[var(--color-text-medium)]"><strong class="font-medium text-[var(--color-primary)]">{lang === 'fr' ? 'Coaching et mentorat' : 'Coaching and mentoring'}</strong> {lang === 'fr' ? 'chaque semaine' : 'every week'}</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-[0.55em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                <span class="text-base text-[var(--color-text-medium)]"><strong class="font-medium text-[var(--color-primary)]">{lang === 'fr' ? 'Bibliothèque de contenus' : 'Content library'}</strong> {lang === 'fr' ? 'pour avancer à ton rythme' : 'to move at your own pace'}</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-[0.55em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                <span class="text-base text-[var(--color-text-medium)]"><strong class="font-medium text-[var(--color-primary)]">{lang === 'fr' ? 'Suivi individuel' : 'Individual follow-up'}</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-[0.55em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                <span class="text-base text-[var(--color-text-medium)]"><strong class="font-medium text-[var(--color-primary)]">{lang === 'fr' ? 'Stages en présentiel' : 'In-person retreats'}</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-[0.55em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                <span class="text-base text-[var(--color-text-medium)]"><strong class="font-medium text-[var(--color-primary)]">{lang === 'fr' ? 'Un groupe qui te soutient' : 'A supportive group'}</strong></span>
              </li>
            </ul>
          </div>
        </div>
        </div>
        <!-- CTA centré dans la section entière -->
        <div class="mt-12 flex justify-center md:mt-16">
          <a href={waitlistUrl} target="_blank" rel="noopener noreferrer" class="btn-accent">{lang === 'fr' ? "Rejoindre la liste d'attente" : 'Join the waitlist'}</a>
        </div>
      </div>
    </section>

    <!-- ============================================
         4. POUR QUI
         ============================================ -->
    <section class="bg-[var(--color-surface)] py-20 md:py-28">
      <div class="mx-auto max-w-5xl px-6">
        <p class="section-label mb-3 text-center text-[var(--color-accent)] tracking-[0.25em]">{t("ei.audience.label")}</p>
        <h2 class="text-center text-4xl md:text-5xl">{t("ei.audience.title")}</h2>
        <p class="mx-auto mt-6 max-w-5xl text-center text-sm italic text-[var(--color-text-medium)] md:text-base md:whitespace-nowrap" set:html={t("ei.audience.intro")}></p>

        <div class="mt-12 grid gap-x-8 gap-y-2 md:mt-14 md:grid-cols-2">
          {[
            { title: "Ton corps tire la sonnette d'alarme", text: t("ei.audience.1"), color: "var(--color-accent)" },
            { title: "Tu sais qu'un autre niveau est possible", text: t("ei.audience.2"), color: "var(--color-warm-dark)" },
            { title: "Ton mental ne s'arrête jamais", text: t("ei.audience.3"), color: "var(--color-sage)" },
            { title: "Tes émotions t'anesthésient ou débordent", text: t("ei.audience.8"), color: "var(--color-blush)" },
            { title: "Tu veux arrêter de subir les fuites d'énergie", text: t("ei.audience.4"), color: "var(--color-accent)" },
            { title: "Tu veux réhabiter ton corps", text: t("ei.audience.5"), color: "var(--color-warm-dark)" },
            { title: "Tu construis quelque chose qui mérite ta meilleure énergie", text: t("ei.audience.6"), color: "var(--color-sage)" },
            { title: "Tu sais, mais tu n'incarnes pas", text: t("ei.audience.7"), color: "var(--color-blush)" },
          ].map((item, i) => (
            <div class="flex items-start gap-5 border-b border-[var(--color-border)] py-5 transition-all hover:bg-[var(--color-warm)] hover:px-4 hover:rounded-lg">
              <span class="flex-shrink-0 mt-1 font-['Josefin_Sans',sans-serif] text-xl font-light leading-none sm:text-2xl" style={`color: ${item.color}`}>{String(i + 1).padStart(2, '0')}</span>
              <div>
                <p class="font-medium text-base text-[var(--color-primary)] md:text-lg">{item.title}</p>
                <p class="mt-1.5 text-sm leading-relaxed text-[var(--color-text-medium)]">{item.text}</p>
              </div>
            </div>
          ))}
        </div>

        <p class="mx-auto mt-12 max-w-3xl text-center text-base text-[var(--color-primary)] md:text-lg">
          {t("ei.audience.bridge")}
        </p>

        <div class="mt-8 mx-auto max-w-4xl rounded-lg border-l-4 border-[var(--color-sage-dark)] bg-[var(--color-sage)]/25 px-7 py-7 sm:px-10 sm:py-9">
          <p class="text-center text-base font-medium text-[var(--color-sage-dark)] leading-relaxed sm:text-lg md:text-xl" set:html={t("ei.audience.conclusion")}></p>
        </div>
      </div>
    </section>

    <!-- ============================================
         5. 4 PILIERS (Méthode — montée pour cohérence page de vente)
         ============================================ -->
    <section class="bg-[var(--color-warm)] py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <p class="section-label mb-3 text-center">{t("ei.pillars.label")}</p>
        <h2 class="text-center text-4xl md:text-5xl">{t("ei.pillars.title")}</h2>
        <div class="divider mx-auto mt-6 mb-12" style="background-color: var(--color-accent);"></div>

        <!-- Grille 4 colonnes desktop, format vertical compact -->
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
          {pillars.map((pillar, i) => {
            const colors = ['var(--color-sage)', 'var(--color-blush)', 'var(--color-accent)', 'var(--color-primary)'];
            const c = colors[i];
            return (
              <div class="flex flex-col rounded-lg border border-[var(--color-border)] border-t-[3px] bg-[var(--color-surface)] p-5 shadow-sm transition-all hover:shadow-md sm:p-6" style={`border-top-color: ${c}`}>
                <!-- Numero + Picto SVG -->
                <div class="mb-4 flex items-center justify-between">
                  <span class="font-['Josefin_Sans',sans-serif] text-4xl font-light" style={`color: ${c}`}>{pillar.num}</span>
                  <svg width="30" height="30" viewBox="0 0 44 44" fill="none" stroke={c} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    {i === 0 && (
                      <>
                        <path d="M22 36 Q14 32 11 24 Q9 15 17 9 Q22 6 27 9 Q35 15 33 24 Q30 32 22 36 Z" fill={c} fill-opacity="0.15" />
                        <path d="M22 36 L22 15" />
                      </>
                    )}
                    {i === 1 && (
                      <>
                        <circle cx="22" cy="9" r="3" fill={c} fill-opacity="0.15" />
                        <line x1="22" y1="12" x2="22" y2="22" />
                        <path d="M22 15 q-7 3 -10 10" />
                        <path d="M22 15 q7 3 10 10" />
                        <path d="M11 29 c 4 -5 18 -5 22 0 c -4 5 -18 5 -22 0 Z" />
                      </>
                    )}
                    {i === 2 && (
                      <>
                        <path d="M22 11 Q18 8 14 10 Q10 12 11 16 Q8 18 9 22 Q9 26 12 27 Q12 31 16 32 Q19 34 22 33 Q25 34 28 32 Q32 31 32 27 Q35 26 35 22 Q36 18 33 16 Q34 12 30 10 Q26 8 22 11 Z" fill={c} fill-opacity="0.15" />
                        <line x1="22" y1="11" x2="22" y2="33" />
                      </>
                    )}
                    {i === 3 && (
                      <>
                        <circle cx="22" cy="22" r="13" fill={c} fill-opacity="0.15" />
                        <circle cx="22" cy="22" r="6" />
                        <circle cx="22" cy="22" r="2" fill={c} />
                      </>
                    )}
                  </svg>
                </div>
                <h3 class="text-lg leading-snug" style={`color: ${c}`}>
                  {i === 2 ? (
                    pillar.title
                  ) : (
                    <>
                      {pillar.title.split('&')[0].trim()}
                      {pillar.title.includes('&') && (
                        <span class="font-light opacity-75"> & {pillar.title.split('&')[1].trim()}</span>
                      )}
                    </>
                  )}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-medium)]">{pillar.text}</p>
                <div class="mt-4 space-y-1.5 border-t border-[var(--color-border)] pt-3">
                  {pillar.benefits.map((benefit) => (
                    <p class="flex items-start gap-2 text-xs text-[var(--color-text-medium)]">
                      <span class="mt-[3px] flex h-3 w-3 shrink-0 items-center justify-center rounded-full text-[7px] text-white" style={`background-color: ${c}`}>✓</span>
                      <span>{benefit}</span>
                    </p>
                  ))}
                </div>
              </div>
            );
          })}
        </div>

        <!-- Roue de la santé + Photo méditation -->
        <div class="mt-16 grid items-center justify-items-center gap-8 md:grid-cols-2 md:gap-10">
          <img
            src="/images/roue-sante-amawe.webp"
            alt="La Roue de la Santé Holistique, les 16 domaines évalués dans Énergie Illimitée"
            width="800"
            height="756"
            loading="lazy"
            decoding="async"
            class="w-full max-w-lg bg-[var(--color-surface)] p-6 rounded-2xl md:h-[480px] md:object-contain md:w-auto"
          />
          <img
            src="/images/claire-orriols-meditation-yoga-aveyron-energie-illimitee.webp"
            alt="Claire Orriols en posture de méditation yoga en pleine nature en Aveyron — Programme Énergie Illimitée, santé holistique"
            width="1000"
            height="1500"
            loading="lazy"
            decoding="async"
            class="w-full max-w-sm rounded-2xl md:h-[480px] md:w-auto md:object-cover"
          />
        </div>

        <!-- CTA déplacé depuis la citation -->
        <div class="mt-12 flex flex-col items-center md:mt-16">
          <a href={waitlistUrl} target="_blank" rel="noopener noreferrer" class="btn-accent !text-sm !px-9 !py-4 md:!text-base md:!px-11 md:!py-5">{lang === 'fr' ? "Je m'inscris sur la liste d'attente" : 'Join the waitlist'}</a>
          <p class="mt-3 text-sm italic text-[var(--color-text-medium)]">{lang === 'fr' ? "Pour recevoir toutes les infos en avant-première" : 'To get all the info in early access'}</p>
        </div>
      </div>
    </section>

    <!-- Bannière citation — pleine largeur, fond dégradé hero, compacte -->
    <section class="py-10 md:py-12" style="background: linear-gradient(135deg, #CE766A 0%, #8B5A7A 50%, #1A1A1A 100%);">
      <div class="mx-auto max-w-3xl px-6 text-center">
