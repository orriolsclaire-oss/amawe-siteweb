---
import Layout from "~/layouts/Layout.astro"
import Header from "~/components/Header.astro"
import Footer from "~/components/Footer.astro"
import SubscribeForm from "~/components/SubscribeForm.astro"

const after = [
  {
    key: "ei",
    title: "Énergie Illimitée",
    text: "Restaurer ta vitalité physique,<br />mentale et émotionnelle",
    href: "/energie-illimitee/",
  },
  {
    key: "summercamp",
    title: "Summer Camp",
    text: "Festival mouvement &amp; santé naturelle · 11-14 juillet 2026",
    href: "/summer-camp/",
  },
  {
    // À propos — non cliquable tant que la page n'est pas terminée
    key: "apropos",
    title: "À propos",
    text: "Claire & l'histoire d'Amawé",
    href: null,
  },
]
---

<Layout
  title="L'Audit de ta Roue de la Santé — Amawé"
  description="Un PDF d'auto-évaluation pour photographier honnêtement ton équilibre — 16 domaines, 4 axes."
>
  <Header />
  <main class="pt-20">
    <!-- ============================================
         1. HERO
         ============================================ -->
    <section class="bg-[var(--color-warm)] py-12 md:py-16">
      <div class="mx-auto max-w-3xl lg:max-w-5xl px-6 text-center">
        <p class="section-label mb-4 text-[var(--color-accent-dark)]">
          AMAWÉ
        </p>
        <h1 class="hero-title lg:whitespace-nowrap">L'Audit de ta Roue de la Santé</h1>
        <p
          class="mt-5 font-['Josefin_Sans',sans-serif] text-lg italic text-[var(--color-text-medium)] md:text-xl"
        >
          16 domaines · 4 axes · une cartographie claire de ton niveau d'équilibre et de santé globale
        </p>
        <p class="mt-6 text-lg leading-relaxed text-[var(--color-primary)]">
          La santé n'est pas une checklist. C'est un écosystème.
        </p>
      </div>
    </section>

    <!-- ============================================
         2. MOCKUP AUDIT + FORMULAIRE
         ============================================ -->
    <section class="bg-[var(--color-accent-dark)] py-20 md:py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid items-center gap-12 md:grid-cols-2 md:gap-16">
          <!-- Mockup de l'audit à gauche -->
          <img
            src="/images/audit-roue-sante-mockup.webp"
            alt="Aperçu du PDF de l'Audit de ta Roue de la Santé Amawé"
            width="800"
            height="756"
            loading="lazy"
            decoding="async"
            class="mx-auto w-full max-w-md drop-shadow-2xl"
          />

          <!-- Formulaire à droite -->
          <div>
            <h2 class="!text-[var(--color-surface)] text-3xl md:text-4xl">
              Reçois le PDF dans ta boîte mail
            </h2>
            <div class="mt-8">
              <SubscribeForm
                intent="lead_audit_roue"
                theme="dark"
                cta="Recevoir l'audit"
                ctaSubtext="C'est gratuit"
                extraFields={["name"]}
                nameLabel="Prénom"
                namePlaceholder="Ton prénom"
                emailLabel="Email"
                emailPlaceholder="Ton adresse email"
                buttonClass="btn-accent w-full whitespace-nowrap leading-tight !text-sm !py-3.5 !bg-[var(--color-sage-dark)] !border-[var(--color-sage-dark)] hover:!bg-[var(--color-warm)] hover:!text-[var(--color-primary)] hover:!border-[var(--color-warm)]"
                redirectTo="/audit-roue-sante/merci/"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         3. TEASER — ce que tu vas découvrir
         ============================================ -->
    <section class="bg-[var(--color-surface)] py-16 md:py-20">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <p class="section-label text-[var(--color-accent)]">CE QUE TU VAS DÉCOUVRIR</p>
        <h2 class="mt-4 !text-[var(--color-text-light)] text-2xl md:text-3xl">
          Pas un test. Une photographie honnête de là où tu en es, sans jugement.
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-[var(--color-text-medium)]">
          En quelques minutes, tu obtiens une cartographie claire de ta santé globale.
          Parce qu'un seul domaine en déséquilibre suffit à tirer toute la roue vers le bas…
          et qu'en rééquilibrer un seul peut tout remettre en mouvement.
        </p>

        <div class="mt-10 grid gap-6 text-left sm:grid-cols-3">
          <div class="border-t-2 border-[var(--color-accent)] pt-4">
            <p class="text-sm leading-relaxed text-[var(--color-text-medium)]">
              Ce qui te porte, ce qui te vide — en un coup d'œil.
            </p>
          </div>
          <div class="border-t-2 border-[var(--color-accent)] pt-4">
            <p class="text-sm leading-relaxed text-[var(--color-text-medium)]">
              Les angles morts que tu ne regardes jamais.
            </p>
          </div>
          <div class="border-t-2 border-[var(--color-accent)] pt-4">
            <p class="text-sm leading-relaxed text-[var(--color-text-medium)]">
              Ton prochain levier : <span class="text-[var(--color-primary)]">un seul</span> domaine, une action qui change vraiment les choses.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         5. ET APRÈS — 3 cartes
         ============================================ -->
    <section class="py-20 md:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <p
          class="text-center font-['Josefin_Sans',sans-serif] text-2xl text-[var(--color-text-medium)] md:text-3xl"
        >
          Si tu veux continuer à découvrir l'univers Amawé
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-3 md:gap-8">
          {
            after.map((item) => {
              const Picto = (
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--color-accent)"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  class="mx-auto mb-4"
                >
                  {item.key === "ei" && (
                    <>
                      <circle cx="12" cy="12" r="5" />
                      <line x1="12" y1="1" x2="12" y2="3" />
                      <line x1="12" y1="21" x2="12" y2="23" />
                      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                      <line x1="1" y1="12" x2="3" y2="12" />
                      <line x1="21" y1="12" x2="23" y2="12" />
                      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </>
                  )}
                  {item.key === "summercamp" && (
                    <>
                      <path d="M12 2 L7 10 H17 Z" />
                      <path d="M12 7 L5 17 H19 Z" />
                      <line x1="12" y1="17" x2="12" y2="22" />
                    </>
                  )}
                  {item.key === "apropos" && (
                    <>
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </>
                  )}
                </svg>
              )

              return item.href ? (
                <a
                  href={item.href}
                  class="group block border border-[var(--color-border)] bg-[var(--color-surface)] p-8 text-center transition-shadow hover:shadow-lg"
                >
                  {Picto}
                  <h3 class="mt-2 text-xl !text-[var(--color-primary)] transition-colors group-hover:!text-[var(--color-accent-dark)]">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-sm text-[var(--color-text-medium)]" set:html={item.text} />
                </a>
              ) : (
                <div
                  class="block cursor-not-allowed border border-[var(--color-border)] bg-[var(--color-surface)] p-8 text-center opacity-60"
                  title="Bientôt disponible"
                >
                  {Picto}
                  <h3 class="mt-2 text-xl !text-[var(--color-primary)]">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-sm text-[var(--color-text-medium)]">
                    {item.text}
                  </p>
                </div>
              )
            })
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero-title {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    line-height: 1.1;
    color: var(--color-primary);
  }
</style>
