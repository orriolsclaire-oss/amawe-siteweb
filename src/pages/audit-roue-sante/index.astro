---
import Layout from "~/layouts/Layout.astro"
import Header from "~/components/Header.astro"
import Footer from "~/components/Footer.astro"
import SubscribeForm from "~/components/SubscribeForm.astro"

const steps = [
  { num: "01", verb: "Note", text: "1-10, 15 min" },
  { num: "02", verb: "Marque", text: "points sur les axes" },
  { num: "03", verb: "Relie", text: "toile d'araignée" },
  { num: "04", verb: "Lis", text: "regarde la forme" },
]

const after = [
  {
    key: "ei",
    title: "Énergie Illimitée",
    text: "Le programme d'accompagnement",
    href: "/energie-illimitee/",
  },
  {
    key: "summercamp",
    title: "Summer Camp",
    text: "Festival mouvement & santé naturelle · 11-14 juillet 2026",
    href: "/summer-camp/",
  },
  {
    // À propos — non cliquable tant que la page n'est pas terminée
    key: "apropos",
    title: "À propos",
    text: "Claire & l'histoire d'Amawé",
    href: null,
  },
]
---

<Layout
  title="L'Audit de ta Roue de la Santé — Amawé"
  description="Un PDF d'auto-évaluation pour photographier honnêtement ton équilibre — 16 domaines, 4 axes."
>
  <Header />
  <main class="pt-20">
    <!-- ============================================
         1. HERO
         ============================================ -->
    <section class="bg-[var(--color-warm)] py-12 md:py-16">
      <div class="mx-auto max-w-3xl lg:max-w-5xl px-6 text-center">
        <p class="section-label mb-4 text-[var(--color-accent-dark)]">
          AMAWÉ
        </p>
        <h1 class="hero-title lg:whitespace-nowrap">L'Audit de ta Roue de la Santé</h1>
        <p
          class="mt-5 font-['Josefin_Sans',sans-serif] text-lg italic text-[var(--color-text-medium)] md:text-xl"
        >
          16 domaines · 4 axes · une cartographie claire de ton niveau d'équilibre et de santé globale
        </p>
        <p class="mt-6 text-lg leading-relaxed text-[var(--color-primary)]">
          La santé n'est pas une checklist. C'est un écosystème.
        </p>
      </div>
    </section>

    <!-- ============================================
         2. LA ROUE + MODE D'EMPLOI (fusionnés)
         ============================================ -->
    <section class="bg-[var(--color-warm-dark)] py-20 md:py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid items-center gap-12 md:grid-cols-2 md:gap-16">
          <!-- Roue à gauche -->
          <img
            src="/images/roue-sante-amawe.webp"
            alt="La Roue de la Santé Amawé — 16 domaines, 4 axes"
            width="800"
            height="756"
            loading="lazy"
            decoding="async"
            class="mx-auto w-full max-w-md bg-[var(--color-surface)] p-8 shadow-md"
          />

          <!-- Mode d'emploi à droite, compact -->
          <div>
            <p class="section-label mb-4 text-[var(--color-accent-dark)]">MODE D'EMPLOI</p>
            <h2 class="!text-[var(--color-primary)] text-3xl md:text-4xl">Comment ça marche</h2>
            <ul class="mt-8 space-y-6">
              {
                steps.map((step) => (
                  <li class="flex items-start gap-5">
                    <span class="flex h-11 w-11 flex-none items-center justify-center rounded-full border border-[var(--color-sage-dark)]/30 bg-[var(--color-surface)] font-['Josefin_Sans',sans-serif] text-lg font-light text-[var(--color-sage-dark)]">
                      {step.num}
                    </span>
                    <div>
                      <h3 class="!text-[var(--color-primary)] text-xl leading-tight">
                        {step.verb}
                      </h3>
                      <p class="mt-1 text-sm text-[var(--color-text-light)]">
                        {step.text}
                      </p>
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         4. FORM
         ============================================ -->
    <section class="bg-[var(--color-accent-dark)] py-20 md:py-28">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="text-3xl !text-[var(--color-surface)] md:text-4xl">
          Reçois le PDF dans ta boîte mail
        </h2>
        <div class="mt-10">
          <SubscribeForm
            intent="lead_audit_roue"
            theme="dark"
            cta="Recevoir l'audit"
            ctaSubtext="C'est gratuit"
            extraFields={["name"]}
            nameLabel="Prénom"
            namePlaceholder="Ton prénom"
            emailLabel="Email"
            emailPlaceholder="Ton adresse email"
            buttonClass="btn-accent w-full whitespace-nowrap leading-tight !text-sm !py-3.5 !bg-[var(--color-sage-dark)] !border-[var(--color-sage-dark)] hover:!bg-[var(--color-warm)] hover:!text-[var(--color-primary)] hover:!border-[var(--color-warm)]"
            redirectTo="/audit-roue-sante/merci/"
            class="mx-auto max-w-md md:max-w-none"
          />
        </div>
      </div>
    </section>

    <!-- ============================================
         5. ET APRÈS — 3 cartes
         ============================================ -->
    <section class="py-20 md:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <p
          class="text-center font-['Josefin_Sans',sans-serif] text-2xl italic text-[var(--color-text-medium)] md:text-3xl"
        >
          Si tu veux continuer à découvrir l'univers Amawé
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-3 md:gap-8">
          {
            after.map((item) => {
              const Picto = (
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--color-accent)"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  class="mx-auto mb-4"
                >
                  {item.key === "ei" && (
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                  )}
                  {item.key === "summercamp" && (
                    <>
                      <circle cx="12" cy="12" r="5" />
                      <line x1="12" y1="1" x2="12" y2="3" />
                      <line x1="12" y1="21" x2="12" y2="23" />
                      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                      <line x1="1" y1="12" x2="3" y2="12" />
                      <line x1="21" y1="12" x2="23" y2="12" />
                      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </>
                  )}
                  {item.key === "apropos" && (
                    <>
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </>
                  )}
                </svg>
              )

              return item.href ? (
                <a
                  href={item.href}
                  class="group block border border-[var(--color-border)] bg-[var(--color-surface)] p-8 text-center transition-shadow hover:shadow-lg"
                >
                  {Picto}
                  <h3 class="mt-2 text-xl !text-[var(--color-primary)] transition-colors group-hover:!text-[var(--color-accent-dark)]">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-sm text-[var(--color-text-medium)]">
                    {item.text}
                  </p>
                </a>
              ) : (
                <div
                  class="block cursor-not-allowed border border-[var(--color-border)] bg-[var(--color-surface)] p-8 text-center opacity-60"
                  title="Bientôt disponible"
                >
                  {Picto}
                  <h3 class="mt-2 text-xl !text-[var(--color-primary)]">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-sm text-[var(--color-text-medium)]">
                    {item.text}
                  </p>
                </div>
              )
            })
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero-title {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    line-height: 1.1;
    color: var(--color-primary);
  }
</style>
