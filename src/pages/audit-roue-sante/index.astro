---
import Layout from "~/layouts/Layout.astro"
import Header from "~/components/Header.astro"
import Footer from "~/components/Footer.astro"
import SubscribeForm from "~/components/SubscribeForm.astro"

const after = [
  {
    key: "ei",
    title: "Énergie Illimitée",
    text: "Restaurer ta vitalité physique, mentale et émotionnelle",
    image: "/images/claire-ei-hero-coaching.webp",
    alt: "Programme Énergie Illimitée — Claire Orriols en accompagnement",
    href: "/energie-illimitee/",
  },
  {
    key: "summercamp",
    title: "Summer Camp",
    text: "Festival mouvement &amp; santé naturelle<br />11-14 juillet 2026",
    image: "/images/sc-rassemblement.webp",
    alt: "Amawé Summer Camp — rassemblement en pleine nature, ambiance festival",
    imgClass: "object-[center_70%]",
    href: "/summer-camp/",
  },
  {
    // À propos — non cliquable tant que la page n'est pas terminée
    key: "apropos",
    title: "À propos",
    text: "Claire & l'histoire d'Amawé",
    image: "/images/claire-portrait-souriante.webp",
    alt: "Claire Orriols, fondatrice d'Amawé",
    href: null,
  },
]
---

<Layout
  title="L'Audit de ta Roue de la Santé — Amawé"
  description="Un PDF d'auto-évaluation pour photographier honnêtement ton équilibre — 16 domaines, 4 axes."
>
  <Header />
  <main class="pt-20">
    <!-- ============================================
         1. HERO
         ============================================ -->
    <section class="bg-[var(--color-warm)] py-12 md:py-16">
      <div class="mx-auto max-w-3xl lg:max-w-5xl px-6 text-center">
        <p class="section-label mb-4 text-[var(--color-accent-dark)]">
          AMAWÉ
        </p>
        <h1 class="hero-title lg:whitespace-nowrap">L'Audit de ta Roue de la Santé</h1>
        <p
          class="mt-5 font-['Josefin_Sans',sans-serif] text-lg italic text-[var(--color-text-medium)] md:text-xl"
        >
          16 domaines · 4 axes · une cartographie claire de ton niveau d'équilibre et de santé globale
        </p>
        <p class="mt-6 text-lg leading-relaxed text-[var(--color-primary)]">
          La santé n'est pas une checklist. C'est un écosystème.
        </p>
      </div>
    </section>

    <!-- ============================================
         2. MOCKUP AUDIT + FORMULAIRE
         ============================================ -->
    <section class="bg-[var(--color-accent-dark)] py-20 md:py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid items-center gap-12 md:grid-cols-2 md:gap-16">
          <!-- Mockup de l'audit à gauche -->
          <img
            src="/images/audit-roue-sante-mockup.webp"
            alt="Aperçu du PDF de l'Audit de ta Roue de la Santé Amawé"
            width="800"
            height="756"
            loading="lazy"
            decoding="async"
            class="mx-auto w-full max-w-md drop-shadow-2xl"
          />

          <!-- Formulaire à droite -->
          <div>
            <h2 class="!text-[var(--color-surface)] text-3xl md:text-4xl">
              Reçois le PDF dans ta boîte mail
            </h2>
            <div class="mt-8">
              <SubscribeForm
                intent="lead_audit_roue"
                theme="dark"
                cta="Recevoir l'audit"
                ctaSubtext="C'est gratuit"
                extraFields={["name"]}
                nameLabel="Prénom"
                namePlaceholder="Ton prénom"
                emailLabel="Email"
                emailPlaceholder="Ton adresse email"
                buttonClass="btn-accent w-full whitespace-nowrap leading-tight !text-sm !py-3.5 !bg-[var(--color-sage-dark)] !border-[var(--color-sage-dark)] hover:!bg-[var(--color-warm)] hover:!text-[var(--color-primary)] hover:!border-[var(--color-warm)]"
                redirectTo="/audit-roue-sante/merci/"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         3. TEASER — ce que tu vas découvrir
         ============================================ -->
    <section class="bg-[var(--color-warm)] py-10 md:py-12">
      <div class="mx-auto max-w-5xl px-6">
        <div class="mx-auto max-w-3xl text-center">
          <p class="section-label text-[var(--color-accent)]">CE QUE TU VAS DÉCOUVRIR</p>
          <h2 class="mt-2 !text-[var(--color-text-light)] text-2xl md:text-3xl">
            Pas un test. Une photographie honnête de là où tu en es, sans jugement.
          </h2>
          <p class="mt-3 text-base leading-relaxed text-[var(--color-text-medium)]">
            En quelques minutes, tu obtiens une cartographie claire de ta santé globale.
            Parce que tout est lié : chaque domaine influence les autres, et c'est l'ensemble
            qui dessine ton niveau de vitalité.
          </p>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-3 lg:gap-5">
          <!-- Carte 1 — vert -->
          <div class="flex flex-col rounded-2xl border border-[var(--color-border)] border-t-[3px] bg-[var(--color-surface)] p-5 shadow-sm transition-all hover:shadow-md" style="border-top-color: var(--color-sage);">
            <div class="mb-3 flex items-center justify-between">
              <span class="font-['Josefin_Sans',sans-serif] text-4xl font-light" style="color: var(--color-sage);">01</span>
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </div>
            <h3 class="text-lg leading-snug" style="color: var(--color-sage);">Tes forces et tes zones de travail</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-medium)]">
              En un coup d'œil, tu repères ce qui te porte vraiment et ce qui te vide. Tes ressources, comme tes fuites d'énergie.
            </p>
          </div>

          <!-- Carte 2 — prune -->
          <div class="flex flex-col rounded-2xl border border-[var(--color-border)] border-t-[3px] bg-[var(--color-surface)] p-5 shadow-sm transition-all hover:shadow-md" style="border-top-color: var(--color-blush);">
            <div class="mb-3 flex items-center justify-between">
              <span class="font-['Josefin_Sans',sans-serif] text-4xl font-light" style="color: var(--color-blush);">02</span>
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--color-blush)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
            </div>
            <h3 class="text-lg leading-snug" style="color: var(--color-blush);">Tes angles morts</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-medium)]">
              Ces domaines qu'on oublie parce qu'on n'y pense jamais. La roue les met en lumière, même ceux qui dérangent ou ceux dont on n'a pas conscience.
            </p>
          </div>

          <!-- Carte 3 — terracotta -->
          <div class="flex flex-col rounded-2xl border border-[var(--color-border)] border-t-[3px] bg-[var(--color-surface)] p-5 shadow-sm transition-all hover:shadow-md" style="border-top-color: var(--color-accent);">
            <div class="mb-3 flex items-center justify-between">
              <span class="font-['Josefin_Sans',sans-serif] text-4xl font-light" style="color: var(--color-accent);">03</span>
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <circle cx="12" cy="12" r="5" />
                <circle cx="12" cy="12" r="1.5" fill="var(--color-accent)" />
              </svg>
            </div>
            <h3 class="text-lg leading-snug" style="color: var(--color-accent);">Ton prochain pas</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-medium)]">
              Pas une liste sans fin. Juste où porter ton attention en premier, et une action concrète pour avancer vers une meilleure santé.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         4. FORMULAIRE (évite de remonter)
         ============================================ -->
    <section class="bg-[var(--color-accent-dark)] py-12 md:py-16">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="text-3xl !text-[var(--color-surface)] md:text-4xl">
          Télécharger le PDF<br />et réaliser mon audit maintenant
        </h2>
        <div class="mt-8">
          <SubscribeForm
            intent="lead_audit_roue"
            theme="dark"
            cta="Recevoir l'audit"
            ctaSubtext="C'est gratuit"
            extraFields={["name"]}
            nameLabel="Prénom"
            namePlaceholder="Ton prénom"
            emailLabel="Email"
            emailPlaceholder="Ton adresse email"
            buttonClass="btn-accent w-full whitespace-nowrap leading-tight !text-sm !py-3.5 !bg-[var(--color-sage-dark)] !border-[var(--color-sage-dark)] hover:!bg-[var(--color-warm)] hover:!text-[var(--color-primary)] hover:!border-[var(--color-warm)]"
            redirectTo="/audit-roue-sante/merci/"
            class="mx-auto max-w-md md:max-w-none"
          />
        </div>
      </div>
    </section>

    <!-- ============================================
         5. ET APRÈS — 3 cartes
         ============================================ -->
    <section class="py-14 md:py-16">
      <div class="mx-auto max-w-5xl px-6">
        <p
          class="text-center font-['Josefin_Sans',sans-serif] text-2xl text-[var(--color-text-medium)] md:text-3xl"
        >
          Si tu veux continuer à découvrir l'univers Amawé
        </p>
        <div class="mt-8 grid gap-5 sm:grid-cols-3 md:gap-6">
          {
            after.map((item) => {
              const Media = (
                <img
                  src={item.image}
                  alt={item.alt}
                  width="600"
                  height="450"
                  loading="lazy"
                  decoding="async"
                  class={`aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105 ${item.imgClass ?? ""}`}
                />
              )

              return item.href ? (
                <a
                  href={item.href}
                  class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] transition-shadow hover:shadow-lg"
                >
                  {Media}
                  <div class="p-5">
                    <h3 class="text-lg !text-[var(--color-primary)] transition-colors group-hover:!text-[var(--color-accent-dark)]">
                      {item.title}
                    </h3>
                    <p class="mt-1 text-sm text-[var(--color-text-medium)]" set:html={item.text} />
                  </div>
                </a>
              ) : (
                <div
                  class="flex cursor-not-allowed flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] opacity-60"
                  title="Bientôt disponible"
                >
                  {Media}
                  <div class="p-5">
                    <h3 class="text-lg !text-[var(--color-primary)]">
                      {item.title}
                    </h3>
                    <p class="mt-1 text-sm text-[var(--color-text-medium)]">
                      {item.text}
                    </p>
                  </div>
                </div>
              )
            })
          }
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .hero-title {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    line-height: 1.1;
    color: var(--color-primary);
  }
</style>
