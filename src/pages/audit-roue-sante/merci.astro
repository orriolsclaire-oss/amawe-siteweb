---
import Layout from "~/layouts/Layout.astro"
import Header from "~/components/Header.astro"
import Footer from "~/components/Footer.astro"

const after = [
  {
    title: "Newsletter Amawé",
    text: "1 clé concrète pour ta santé, chaque semaine. Gratuit. Déjà 20 000+ abonnés.",
    image: "/images/claire-orriols-newsletter-superletter-amawe.webp",
    alt: "Claire Orriols écrivant la SuperLetter, la newsletter santé d'Amawé",
    imgClass: "object-[center_30%]",
    href: "/ressources/",
  },
  {
    title: "Summer Camp",
    text: "Festival mouvement &amp; santé naturelle<br />11-14 juillet 2026",
    image: "/images/sc-rassemblement.webp",
    imgClass: "object-[center_70%]",
    alt: "Amawé Summer Camp — rassemblement en pleine nature, ambiance festival",
    href: "/summer-camp/",
  },
  {
    title: "Sur les réseaux",
    text: "Rejoins-moi sur Instagram @amawefrance",
    image: "/images/amawe-instagram-amawefrance-reseaux-sociaux.webp",
    alt: "Le compte Instagram @amawefrance — contenus santé, mouvement et nature",
    href: "https://www.instagram.com/amawefrance/",
    external: true,
  },
]
---

<Layout
  title="Merci — L'Audit de ta Roue de la Santé — Amawé"
  description="Le PDF arrive dans ta boîte mail. En attendant, découvre l'univers Amawé."
>
  <Header />
  <main class="pt-20">
    <section class="bg-[var(--color-warm)] py-14 md:py-20">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-sage)] text-2xl text-white">
          ✓
        </div>
        <h1 class="hero-title">Merci. Le PDF arrive dans ta boîte mail.</h1>
        <p class="mt-5 text-lg leading-relaxed text-[var(--color-text-medium)]">
          Vérifie ton dossier promotions/spam si tu ne le trouves pas. Et ajoute
          <strong class="font-normal text-[var(--color-primary)]">Amawé hello@amawe.com</strong>
          à tes contacts pour être sûr·e de bien recevoir les emails.
        </p>
      </div>
    </section>

    <section class="py-14 md:py-16">
      <div class="mx-auto max-w-5xl px-6">
        <p
          class="text-center font-['Josefin_Sans',sans-serif] text-2xl text-[var(--color-text-medium)] md:text-3xl"
        >
          Si tu veux continuer à découvrir l'univers Amawé
        </p>
        <div class="mt-8 grid gap-5 sm:grid-cols-3 md:gap-6">
          {
            after.map((item) => (
              <a
                href={item.href}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noopener noreferrer" : undefined}
                class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] transition-shadow hover:shadow-lg"
              >
                <img
                  src={item.image}
                  alt={item.alt}
                  width="600"
                  height="450"
                  loading="lazy"
                  decoding="async"
                  class={`aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105 ${item.imgClass ?? ""}`}
                />
                <div class="p-5">
                  <h3 class="text-lg !text-[var(--color-primary)] transition-colors group-hover:!text-[var(--color-accent-dark)]">
                    {item.title}
                  </h3>
                  <p class="mt-1 text-sm text-[var(--color-text-medium)]" set:html={item.text} />
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.2;
    color: var(--color-primary);
  }
</style>
