---
import Layout from "~/layouts/Layout.astro"
import Header from "~/components/Header.astro"
import Footer from "~/components/Footer.astro"
import SubscribeForm from "~/components/SubscribeForm.astro"
import { getLangFromUrl, useTranslations } from "~/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout
  title={`${t("contact.title")} — Amawe`}
  description={t("contact.text")}
>
  <Header />
  <main class="pt-20">

    <section class="py-12 md:py-20">
      <div class="mx-auto max-w-6xl px-6 md:px-8 lg:px-10">
        <div class="grid gap-12 md:grid-cols-2 md:gap-16 lg:gap-20">
          <!-- Left: info -->
          <div>
            <p class="section-label mb-4">{t("contact.label")}</p>
            <h1 class="!text-3xl md:!text-5xl">{t("contact.title")}</h1>
            <div class="divider mt-6" style="background-color: var(--color-sage-dark);"></div>
            <p class="mt-8 text-lg text-[var(--color-text-medium)]" set:html={t("contact.text")}></p>

            <div class="mt-12 space-y-6">
              <div>
                <p class="section-label mb-3">REJOINS LA COMMUNAUTÉ</p>
                <div class="flex items-center gap-5">
                  <a
                    href="https://instagram.com/amawefrance"
                    target="_blank"
                    rel="noopener"
                    aria-label="Suivre Amawé sur Instagram"
                    class="text-[var(--color-text-medium)] transition-colors hover:text-[var(--color-accent-dark)]"
                  >
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  </a>
                  <a
                    href="https://www.facebook.com/amawefrance"
                    target="_blank"
                    rel="noopener"
                    aria-label="Suivre Amawé sur Facebook"
                    class="text-[var(--color-text-medium)] transition-colors hover:text-[var(--color-accent-dark)]"
                  >
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                  </a>
                  <a
                    href="https://www.youtube.com/@amawe"
                    target="_blank"
                    rel="noopener"
                    aria-label="Suivre Amawé sur YouTube"
                    class="text-[var(--color-text-medium)] transition-colors hover:text-[var(--color-accent-dark)]"
                  >
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
                  </a>
                </div>
                <p class="mt-3 text-sm text-[var(--color-text-light)]">
                  <a href="https://instagram.com/amawefrance" target="_blank" rel="noopener" class="hover:text-[var(--color-accent-dark)] transition-colors">@amawefrance</a> · personnel : <a href="https://instagram.com/claireorriols" target="_blank" rel="noopener" class="hover:text-[var(--color-accent-dark)] transition-colors">@claireorriols</a>
                </p>
              </div>
            </div>
          </div>

          <!-- Right: form -->
          <div>
            <div class="mx-auto max-w-md bg-[var(--color-surface)] p-6 md:mr-8 md:p-8">
            <SubscribeForm
              intent="contact"
              theme="underline"
              extraFields={["name", "subject", "message"]}
              cta={t("contact.form.send")}
              nameLabel={t("contact.form.name")}
              emailLabel={t("contact.form.email")}
              messageLabel={t("contact.form.message")}
              namePlaceholder=""
              emailPlaceholder=""
              messagePlaceholder=""
              buttonClass="w-full inline-block px-8 py-3 font-['Lato',system-ui,sans-serif] text-xs font-medium uppercase tracking-[0.12em] text-[var(--color-surface)] bg-[var(--color-accent-dark)] border-2 border-[var(--color-accent-dark)] rounded-full transition-all duration-300 hover:bg-[var(--color-accent)] hover:border-[var(--color-accent)] cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
            />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
