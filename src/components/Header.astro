---
import { getLangFromUrl, useTranslations } from "~/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<!-- Wrapper fixed : header + bandeau actu restent visibles ensemble au scroll -->
<div class="fixed top-0 z-50 w-full">
  <!-- Header — fixed, se réduit au scroll (shrink on scroll) -->
  <header id="site-header" class="w-full bg-[var(--color-surface)]/95 backdrop-blur-md transition-all duration-300">
  <nav id="site-nav" class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5 transition-all duration-300">
    <!-- Logo -->
    <a id="site-logo" href="/" class="font-['Josefin_Sans',sans-serif] text-2xl font-light tracking-[0.15em] uppercase transition-all duration-300">
      Amawé
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 md:flex lg:gap-7">
      <a href="/ressources/" class="section-label hover:text-[var(--color-accent)] transition-colors">
        Ressources
      </a>
      <a href="/energie-illimitee/" class="section-label hover:text-[var(--color-accent)] transition-colors">
        {t("nav.program")}
      </a>
      <a href="/summer-camp/" class="section-label hover:text-[var(--color-accent)] transition-colors text-[var(--color-accent)]">
        Summer Camp
      </a>
      <a href="/stages/" class="section-label hover:text-[var(--color-accent)] transition-colors">
        Stages
      </a>
      <span class="section-label cursor-not-allowed opacity-60" title="Bientôt disponible">
        {t("nav.about")}
      </span>
      <a href="/contact/" class="section-label hover:text-[var(--color-accent)] transition-colors">
        {t("nav.contact")}
      </a>
      <a
        href="https://mesprogrammes.amawe.com/login"
        target="_blank"
        rel="noopener"
        class="btn-nav ml-2"
      >
        Connexion
      </a>
    </div>

    <!-- Mobile burger -->
    <button
      id="mobile-menu-toggle"
      class="flex flex-col gap-1.5 md:hidden"
      aria-label="Menu"
    >
      <span class="block h-px w-6 bg-[var(--color-primary)] transition-transform"></span>
      <span class="block h-px w-6 bg-[var(--color-primary)] transition-opacity"></span>
      <span class="block h-px w-6 bg-[var(--color-primary)] transition-transform"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-border)] bg-[var(--color-surface)] md:hidden">
    <div class="flex flex-col items-center gap-6 py-8">
      <a href="/ressources/" class="section-label">Ressources</a>
      <a href="/energie-illimitee/" class="section-label">{t("nav.program")}</a>
      <a href="/summer-camp/" class="section-label text-[var(--color-accent)]">Summer Camp</a>
      <a href="/stages/" class="section-label">Stages</a>
      <span class="section-label cursor-not-allowed opacity-60" title="Bientôt disponible">{t("nav.about")}</span>
      <a href="/contact/" class="section-label">{t("nav.contact")}</a>
      <a
        href="https://mesprogrammes.amawe.com/login"
        target="_blank"
        rel="noopener"
        class="btn-nav"
      >
        Connexion
      </a>
    </div>
  </div>
  </header>

  <!-- Bandeau actu — Summer Camp 2026 (en dessous du menu) -->
  <a
    href="/summer-camp/"
    class="block w-full bg-[var(--color-sage-dark)] text-center text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-surface)] transition-opacity hover:opacity-90"
    style="padding: 0.55rem 1rem;"
  >
    <span class="hidden sm:inline">Summer Camp Amawé · 11-14 juillet 2026 · Places limitées · Inscription →</span>
    <span class="sm:hidden">Summer Camp · 11-14 juillet 2026 →</span>
  </a>
  <!-- Trait blanc pour séparer visuellement le bandeau du contenu en-dessous -->
  <div class="h-[3px] bg-white" aria-hidden="true"></div>
</div>

<script is:inline>
  // Mobile menu toggle
  const toggle = document.getElementById("mobile-menu-toggle")
  const menu = document.getElementById("mobile-menu")
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      menu.classList.toggle("hidden")
    })
  }

  // Header shrink on scroll — divise par 2 dès qu'on scrolle
  const nav = document.getElementById("site-nav")
  const logo = document.getElementById("site-logo")
  if (nav && logo) {
    const onScroll = () => {
      if (window.scrollY > 30) {
        // Version compactée : padding et logo divisés par ~2
        nav.style.paddingTop = "0.5rem"
        nav.style.paddingBottom = "0.5rem"
        logo.style.fontSize = "1rem"
      } else {
        // Version normale : remet les valeurs par défaut
        nav.style.paddingTop = ""
        nav.style.paddingBottom = ""
        logo.style.fontSize = ""
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true })
    onScroll()
  }
</script>
