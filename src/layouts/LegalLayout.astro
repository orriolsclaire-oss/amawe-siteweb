---
import Layout from "~/layouts/Layout.astro"
import Header from "~/components/Header.astro"
import Footer from "~/components/Footer.astro"

interface Props {
  title: string
  description?: string
  lastUpdated?: string
}

const { title, description, lastUpdated } = Astro.props as Props
---

<Layout title={`${title} — Amawé`} description={description}>
  <Header />
  <main class="pt-20">
    <article class="mx-auto max-w-3xl px-6 py-20 md:py-28">
      <header class="mb-12 border-b border-[var(--color-border)] pb-8">
        <h1 class="text-4xl md:text-5xl">{title}</h1>
        {
          lastUpdated && (
            <p class="mt-4 text-sm text-[var(--color-text-light)]">
              Dernière mise à jour : {lastUpdated}
            </p>
          )
        }
      </header>
      <div class="prose-legal">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  article header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.2;
  }
  .prose-legal :global(h2) {
    font-family: "Josefin Sans", sans-serif;
    font-weight: 300;
    font-size: 1.75rem;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }
  .prose-legal :global(h3) {
    font-family: "Josefin Sans", sans-serif;
    font-weight: 400;
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }
  .prose-legal :global(p) {
    margin-bottom: 1rem;
    line-height: 1.8;
    color: var(--color-text-medium);
  }
  .prose-legal :global(ul),
  .prose-legal :global(ol) {
    margin: 0 0 1rem 0;
    padding-left: 1.5rem;
    line-height: 1.8;
    color: var(--color-text-medium);
  }
  .prose-legal :global(li) {
    margin-bottom: 0.5rem;
  }
  .prose-legal :global(table) {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .prose-legal :global(th),
  .prose-legal :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    text-align: left;
    vertical-align: top;
  }
  .prose-legal :global(th) {
    background: var(--color-warm);
    font-weight: 500;
    color: var(--color-primary);
  }
  .prose-legal :global(strong) {
    color: var(--color-primary);
    font-weight: 500;
  }
  .prose-legal :global(a) {
    color: var(--color-accent-dark);
    text-decoration: underline;
  }
  .prose-legal :global(a:hover) {
    color: var(--color-primary);
  }
  .prose-legal :global(hr) {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid var(--color-border);
  }
  .prose-legal :global(blockquote) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
    border-left: 3px solid var(--color-sage-dark);
    color: var(--color-text-medium);
    font-style: italic;
  }
</style>
